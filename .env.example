# ============================================================
# WIDIRS - Web Defacement Investigation & Response System
# Copy this file to .env and fill in your values.
# NEVER commit your real .env file to version control.
# ============================================================

# ---------------- AI / LLM (FREE - Google Gemini) ----------------
# Get a FREE API key at: https://aistudio.google.com/app/apikey
# Free tier: 15 requests/min, 1 million tokens/day, no credit card needed
GOOGLE_API_KEY=

# ---------------- Threat Intelligence ----------------
VIRUSTOTAL_API_KEY=
ABUSEIPDB_API_KEY=
SHODAN_API_KEY=                 # optional
MISP_URL=                       # optional, e.g. https://misp.example.org
MISP_KEY=                       # optional

# ---------------- Alerting: Telegram ----------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_IDS=              # comma-separated chat IDs, e.g. 12345,67890

# ---------------- Alerting: Email ----------------
# Transport selection: if SMTP_HOST is set, SMTP (STARTTLS) is used;
# otherwise SendGrid is used when SENDGRID_API_KEY is set.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SENDGRID_API_KEY=               # used when SMTP_HOST is empty
ALERT_EMAIL_FROM=               # verified sender address (required for SendGrid)
ALERT_EMAIL_TO=                 # comma-separated recipient addresses

# ---------------- System ----------------
SNAPSHOT_DIR=data/snapshots     # where HTML + screenshot snapshots are stored
REPORT_DIR=data/reports         # where generated HTML/PDF reports are stored
DB_PATH=data/db/widirs.db       # SQLite database path
LOG_LEVEL=INFO                  # DEBUG | INFO | WARNING | ERROR
CONCURRENT_SCANS=5              # max parallel site scans
SCAN_INTERVAL=300               # default scan interval in seconds
TI_CACHE_TTL_HOURS=24           # threat-intel cache TTL
MIN_CHANGE_SCORE=0.10           # minimum change score (0-1) to trigger analysis
MIN_SEVERITY_TO_ALERT=medium    # low | medium | high | critical
